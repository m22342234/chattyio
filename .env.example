# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
# Use the test keys below for local dev; replace with real keys before deployment.
CF_TURNSTILE_SITE_KEY=1x00000000000000000000AA
CF_TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# Cloudflare Web Analytics — https://dash.cloudflare.com/?to=/:account/web-analytics
# Leave empty in dev; paste your beacon token from the Cloudflare dashboard for production.
CF_ANALYTICS_TOKEN=

# Server listening port
PORT=3000
