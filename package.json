{
  "name": "chattyio",
  "version": "1.0.0",
  "description": "Free anonymous text chat — no account, no logs, zero data retention",
  "main": "server/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./client/css/input.css -o ./client/public/css/tailwind.css --minify",
    "build:og": "node scripts/generate-og.js",
    "build": "npm run build:css && npm run build:og",
    "start": "npm run build && node server/index.js",
    "dev": "nodemon server/index.js"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "rate-limiter-flexible": "^11.2.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.19"
  }
}
